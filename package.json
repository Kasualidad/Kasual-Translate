{
  "name": "kasual-translate",
  "private": true,
  "version": "2.0.0",
  "description": "Herramienta de extraccion y traduccion para mods de Project Zomboid.",
  "author": "Kasual",
  "repository": {
    "type": "git",
    "url": "https://github.com/Kasualidad/Kasual-Translate.git"
  },
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "clean:release": "node -e \"require('fs').rmSync('release', { recursive: true, force: true })\"",
    "build": "tsc -p tsconfig.app.json && vite build",
    "electron:pack": "npm run clean:release && npm run build && electron-builder --win portable --publish never",
    "electron:release": "npm run clean:release && npm run build && electron-builder --win portable --publish always",
    "electron:dir": "npm run build && electron-builder --win dir",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@types/codemirror": "^5.60.17",
    "@types/jszip": "^3.4.0",
    "codemirror": "^5.65.21",
    "dexie": "^4.3.0",
    "jszip": "^3.10.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-icons": "^5.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^8.0.0-beta.13"
  },
  "build": {
    "appId": "com.kasual.translate",
    "productName": "Kasual Translate",
    "directories": {
      "output": "release"
    },
    "asar": true,
    "compression": "maximum",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "portable"
      ],
      "signAndEditExecutable": false,
      "icon": "electron/assets/kasual-logo.ico"
    },
    "publish": {
      "provider": "github",
      "owner": "Kasualidad",
      "repo": "Kasual-Translate",
      "releaseType": "release"
    }
  },
  "overrides": {
    "vite": "^8.0.0-beta.13"
  }
}
